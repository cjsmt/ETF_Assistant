# === LLM API (required) ===
# AIHubMix + DeepSeek example:
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://aihubmix.com/v1
OPENAI_MODEL=deepseek-v3.2

# Or direct OpenAI / DeepSeek:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# === News & Macro APIs (optional) ===
# Jina: Chinese web search + scrape, https://jina.ai/
JINA_API_KEY=your_jina_api_key_here

# Alpha Vantage: Global news + macro, https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# AKShare: A-share flash/news - no key needed (free)
# search_news / search_news_cn / get_macro_events use AKShare by default

# === Tushare (optional, 用于 ETF 规模/成交额，替代易断的 fund_etf_spot_em) ===
# 设置后 map_etf 优先用 Tushare 拉取 ETF 信息
TUSHARE_TOKEN=your_tushare_token
# 若使用自定义/代理 API 地址（如示例中的）：
# TUSHARE_API_URL=http://lianghua.nanyangqiankun.top
